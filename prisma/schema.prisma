generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id                           Int                    @id @default(autoincrement())
  username                     String                 @unique
  fullName                     String?
  email                        String                 @unique
  passwordHash                 String?
  piUid                        String?                @unique
  piUsername                   String?
  piWalletAddress              String?
  piLinkedAt                   DateTime?
  piAuthVerified               Boolean                @default(false)
  roleId                       Int
  status                       UserStatus             @default(PENDING)
  profileImage                 String?
  coverImage                   String?
  headline                     String?
  bio                          String?
  country                      String?
  customCountryName            String?
  phoneNumber                  String?                @unique
  showEmailPublic              Boolean                @default(false)
  showPhonePublic              Boolean                @default(false)
  showCountryPublic            Boolean                @default(true)
  websiteUrl                   String?
  twitterUrl                   String?
  instagramUrl                 String?
  lastLoginAt                  DateTime?
  canEditCommentsAfterDeadline Boolean                @default(false)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  artistProfile                ArtistProfile?
  artworks                     Artwork[]
  comments                     ArtworkComment[]
  reactions                    ArtworkReaction[]
  submittedArtworkReports      ArtworkReport[]        @relation("ArtworkReportReporter")
  reviewedArtworkReports       ArtworkReport[]        @relation("ArtworkReportReviewer")
  auditLogs                    AuditLog[]
  commentLikes                 CommentLike[]
  submittedCommentReports      CommentReport[]        @relation("CommentReportReporter")
  reviewedCommentReports       CommentReport[]        @relation("CommentReportReviewer")
  activities                   CommunityActivity[]    @relation("ActivityActor")
  receivedActivities           CommunityActivity[]    @relation("ActivitySubject")
  posts                        CommunityPost[]
  postComments                 CommunityPostComment[]
  postLikes                    CommunityPostLike[]
  favorites                    Favorite[]
  following                    Follow[]               @relation("UserFollowing")
  followers                    Follow[]               @relation("UserFollowers")
  notifications                Notification[]
  purchasePayments             PiPayment[]            @relation("PiPaymentBuyer")
  salesPayments                PiPayment[]            @relation("PiPaymentSeller")
  ratings                      Rating[]
  role                         Role                   @relation(fields: [roleId], references: [id])
}

model Follow {
  id                    Int      @id @default(autoincrement())
  followerId            Int
  followingId           Int
  notifyMode            String   @default("ALL")
  notificationsEnabled  Boolean  @default(true)
  notifyAllActivity     Boolean  @default(true)
  notifyNewArtworks     Boolean  @default(true)
  notifyPremiumArtworks Boolean  @default(true)
  notifyComments        Boolean  @default(true)
  muted                 Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
  follower              User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following             User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ArtistProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  displayName   String
  slug          String   @unique
  headline      String?
  biography     String?
  verified      Boolean  @default(false)
  totalArtworks Int      @default(0)
  totalSales    Decimal  @default(0) @db.Decimal(12, 2)
  totalRating   Decimal  @default(0) @db.Decimal(4, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isoCode   String   @unique
  phoneCode String
  allowed   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArtworkCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  artworks    Artwork[]
}

model Artwork {
  id                     Int               @id @default(autoincrement())
  artistUserId           Int
  categoryId             Int?
  title                  String
  slug                   String            @unique
  description            String
  imageUrl               String
  thumbnailUrl           String?
  status                 ArtworkStatus     @default(DRAFT)
  basePrice              Decimal           @default(0) @db.Decimal(12, 2)
  discountPercent        Float             @default(0)
  price                  Decimal           @db.Decimal(12, 2)
  currency               String            @default("PI")
  featured               Boolean           @default(false)
  viewsCount             Int               @default(0)
  favoritesCount         Int               @default(0)
  averageRating          Decimal           @default(0) @db.Decimal(3, 2)
  ratingsCount           Int               @default(0)
  likesCount             Int               @default(0)
  dislikesCount          Int               @default(0)
  premiumScore           Float?            @default(0)
  premiumAt              DateTime?
  publishedAt            DateTime?
  reviewNote             String?
  reviewedAt             DateTime?
  publicReviewStartedAt  DateTime?
  mintWindowOpensAt      DateTime?
  mintWindowEndsAt       DateTime?
  mintedAt               DateTime?
  statusBeforeModeration String?
  statusBeforeArchive    String?
  archivedAt             DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  artist                 User              @relation(fields: [artistUserId], references: [id])
  category               ArtworkCategory?  @relation(fields: [categoryId], references: [id])
  comments               ArtworkComment[]
  reactions              ArtworkReaction[]
  reports                ArtworkReport[]
  communityPosts         CommunityPost[]
  favorites              Favorite[]
  payments               PiPayment[]
  ratings                Rating[]

  @@index([artistUserId])
  @@index([categoryId])
}

model PiPayment {
  id                Int       @id @default(autoincrement())
  paymentIdentifier String    @unique
  artworkId         Int
  buyerUserId       Int
  sellerUserId      Int
  amount            Float
  memo              String?
  network           String?   @default("Pi Testnet")
  txid              String?   @unique
  status            String    @default("CREATED")
  rawPayload        Json?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  artwork           Artwork   @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  buyer             User      @relation("PiPaymentBuyer", fields: [buyerUserId], references: [id], onDelete: Cascade)
  seller            User      @relation("PiPaymentSeller", fields: [sellerUserId], references: [id], onDelete: Cascade)

  @@index([artworkId])
  @@index([buyerUserId])
  @@index([sellerUserId])
  @@index([status])
}

model Rating {
  id         Int      @id @default(autoincrement())
  artworkId  Int
  userId     Int
  value      Int
  reviewText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  artwork    Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artworkId, userId])
  @@index([artworkId])
  @@index([userId])
}

model ArtworkComment {
  id                 Int              @id @default(autoincrement())
  artworkId          Int
  authorId           Int
  parentId           Int?
  commentKind        String           @default("FIRST_COMMENT")
  stanceType         String?
  body               String
  scoreImpact        Float            @default(0)
  scoreEffectEnabled Boolean          @default(true)
  hiddenByArtist     Boolean          @default(false)
  hiddenByModerator  Boolean          @default(false)
  editLockedAt       DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  artwork            Artwork          @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  author             User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent             ArtworkComment?  @relation("ArtworkCommentReplies", fields: [parentId], references: [id])
  replies            ArtworkComment[] @relation("ArtworkCommentReplies")
  commentLikes       CommentLike[]
  reports            CommentReport[]

  @@index([artworkId])
  @@index([authorId])
  @@index([parentId])
}

model CommentLike {
  id        Int            @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime       @default(now())
  comment   ArtworkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model ArtworkReport {
  id                 Int                     @id @default(autoincrement())
  artworkId          Int
  reporterId         Int
  reviewedById       Int?
  reason             String
  description        String?
  originalWorkLink   String?
  evidenceLink       String?
  contactEmail       String?
  status             String                  @default("PENDING")
  autoBlockedApplied Boolean                 @default(false)
  adminNote          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  artwork            Artwork                 @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  reporter           User                    @relation("ArtworkReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy         User?                   @relation("ArtworkReportReviewer", fields: [reviewedById], references: [id])
  evidenceFiles      ArtworkReportEvidence[]

  @@index([artworkId])
  @@index([reporterId])
  @@index([status])
}

model ArtworkReportEvidence {
  id           Int           @id @default(autoincrement())
  reportId     Int
  fileUrl      String
  originalName String?
  mimeType     String?
  createdAt    DateTime      @default(now())
  report       ArtworkReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model CommentReport {
  id           Int            @id @default(autoincrement())
  commentId    Int
  reporterId   Int
  reviewedById Int?
  reason       String
  description  String?
  status       String         @default("PENDING")
  adminNote    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  comment      ArtworkComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter     User           @relation("CommentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy   User?          @relation("CommentReportReviewer", fields: [reviewedById], references: [id])

  @@index([commentId])
  @@index([reporterId])
  @@index([status])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  artworkId Int
  createdAt DateTime @default(now())
  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
}

model ArtworkReaction {
  id        Int          @id @default(autoincrement())
  artworkId Int
  userId    Int
  type      ReactionType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  artwork   Artwork      @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artworkId, userId])
  @@index([artworkId])
  @@index([userId])
}

model Page {
  id             Int           @id @default(autoincrement())
  title          String
  slug           String        @unique
  pageType       String?
  status         PageStatus    @default(DRAFT)
  menuLabel      String?
  showInMenu     Boolean       @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sections       PageSection[]
}

model PageSection {
  id           Int      @id @default(autoincrement())
  pageId       Int
  sectionKey   String
  sectionType  String
  title        String?
  content      String?
  settingsJson Json?
  sortOrder    Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model SiteSetting {
  id           Int      @id @default(autoincrement())
  settingKey   String   @unique
  settingValue String?
  settingGroup String?
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HomepageSlide {
  id         Int      @id @default(autoincrement())
  title      String
  subtitle   String?
  imageUrl   String
  buttonText String?
  buttonLink String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CommunityPost {
  id            Int                    @id @default(autoincrement())
  authorId      Int
  title         String?
  body          String
  imageUrl      String?
  isPublished   Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  commentsCount Int                    @default(0)
  likesCount    Int                    @default(0)
  artworkId     Int?
  artwork       Artwork?               @relation(fields: [artworkId], references: [id])
  author        User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments      CommunityPostComment[]
  likes         CommunityPostLike[]

  @@index([authorId])
  @@index([artworkId])
  @@index([createdAt])
  @@index([isPublished, createdAt])
}

model CommunityPostLike {
  id        Int           @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model CommunityPostComment {
  id        Int                    @id @default(autoincrement())
  postId    Int
  authorId  Int
  body      String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  parentId  Int?
  author    User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    CommunityPostComment?  @relation("CommunityPostCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   CommunityPostComment[] @relation("CommunityPostCommentReplies")
  post      CommunityPost          @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model CommunityActivity {
  id            Int      @id @default(autoincrement())
  actorId       Int
  subjectUserId Int?
  type          String
  title         String
  message       String
  linkUrl       String?
  createdAt     DateTime @default(now())
  actor         User     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  subjectUser   User?    @relation("ActivitySubject", fields: [subjectUserId], references: [id])

  @@index([actorId])
  @@index([subjectUserId])
  @@index([createdAt])
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  action        String
  targetType    String
  targetId      String?
  oldValuesJson Json?
  newValuesJson Json?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
  BANNED
}

enum ArtworkStatus {
  DRAFT
  PENDING
  APPROVED
  PUBLIC_REVIEW
  MINTING
  PUBLISHED
  PREMIUM
  REJECTED
  ARCHIVED
  HIDDEN
  SOLD
}

enum PageStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum ReactionType {
  LIKE
  DISLIKE
}
